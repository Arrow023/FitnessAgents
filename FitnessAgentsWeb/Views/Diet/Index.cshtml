@model DietListViewModel
@{
    ViewData["Title"] = "Diet Plan";
}

<div class="page-header fade-up">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="page-title">Diet Plan</h1>
            <p class="page-subtitle">AI-powered macro-optimized nutrition plans.</p>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <form method="post" asp-controller="Diet" asp-action="ResendEmail" style="margin: 0;">
                <input type="hidden" name="userId" value="@Model.UserId" />
                <button type="submit" class="btn btn-outline btn-sm">
                    <i class="fa-solid fa-envelope"></i> Email Latest
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Today's Diet (Featured) -->
@if (Model.LatestDiet is not null)
{
    <div class="card fade-up" style="margin-bottom: 1.75rem;">
        <div class="card-header" style="margin-bottom: 1.25rem;">
            <div>
                <h3 class="card-title" style="font-size: 1.2rem;">Today's Nutrition Plan</h3>
                <p class="card-subtitle"><i class="fa-solid fa-robot"></i> @Model.LatestDiet.AiSummary</p>
            </div>
            <div style="text-align: right;">
                <div style="font-size: 1.5rem; font-weight: 800; color: var(--primary);">@Model.LatestDiet.TotalCaloriesTarget</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">kcal target</div>
            </div>
        </div>

        @{
            var groupedMeals = Model.LatestDiet.Meals.GroupBy(m => m.MealType);
        }
        @foreach (var group in groupedMeals)
        {
            <div class="meal-group-label">@group.Key</div>
            @foreach (var meal in group)
            {
                <div class="meal-row">
                    <div>
                        <span class="meal-row-name">@meal.FoodName</span>
                        <span class="meal-row-qty">(@meal.QuantityDescription)</span>
                    </div>
                    <span class="meal-row-kcal">@meal.Calories kcal</span>
                </div>
            }
        }

        <!-- Inline Quick Feedback -->
        <div id="dietInlineFeedback" style="margin-top: 1.25rem; padding: 0.85rem 1rem; background: var(--primary-subtle); border-radius: 0.75rem; border: 1px solid color-mix(in srgb, var(--primary) 15%, transparent);">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
                <span style="font-size: 0.85rem; font-weight: 600; color: var(--text);">How's today's diet plan?</span>
                <div style="display: flex; align-items: center; gap: 0.4rem;">
                    <button type="button" class="diet-feedback-btn" data-rating="5" onclick="submitDietQuickFeedback(5, 'just-right')"
                            style="padding: 0.3rem 0.65rem; border: 1.5px solid var(--border); border-radius: 0.5rem; background: transparent; cursor: pointer; font-size: 0.95rem; transition: all 0.15s;" title="Great!">👍</button>
                    <button type="button" class="diet-feedback-btn" data-rating="3" onclick="submitDietQuickFeedback(3, 'just-right')"
                            style="padding: 0.3rem 0.65rem; border: 1.5px solid var(--border); border-radius: 0.5rem; background: transparent; cursor: pointer; font-size: 0.95rem; transition: all 0.15s;" title="Okay">😐</button>
                    <button type="button" class="diet-feedback-btn" data-rating="1" onclick="submitDietQuickFeedback(1, 'too-much')"
                            style="padding: 0.3rem 0.65rem; border: 1.5px solid var(--border); border-radius: 0.5rem; background: transparent; cursor: pointer; font-size: 0.95rem; transition: all 0.15s;" title="Not great">👎</button>
                    <a href="@Url.Action("Feedback", "Diet", new { userId = Model.UserId })" style="font-size: 0.72rem; color: var(--text-secondary); margin-left: 0.5rem; text-decoration: underline;">Detailed feedback</a>
                </div>
            </div>
            <div id="dietFeedbackStatus" style="display: none; margin-top: 0.4rem; font-size: 0.78rem; color: var(--accent-green); font-weight: 600;">
                <i class="fa-solid fa-check-circle"></i> Feedback saved!
            </div>
        </div>
    </div>
}
else
{
    <div class="empty-state fade-up" style="margin-bottom: 1.75rem;">
        <div class="empty-state-icon"><i class="fa-solid fa-bowl-rice"></i></div>
        <div class="empty-state-title">No diet plan for today</div>
        <div class="empty-state-text">Generate a workout first — your AI nutritionist creates plans based on today's training.</div>
    </div>
}

<!-- Diet History -->
<h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text); margin-bottom: 1rem;" class="fade-up">This Week's History</h2>

@if (Model.DietHistory is not null && Model.DietHistory.PastDiets.Count > 0)
{
    <div class="grid-auto">
        @{ var delay = 0; }
        @foreach (var dayPlan in Model.DietHistory.PastDiets.OrderByDescending(x => x.Key))
        {
            delay++;
            <a href="/Diet/Detail?userId=@Model.UserId&day=@dayPlan.Key" style="text-decoration: none;" class="fade-up stagger-@(Math.Min(delay, 4))">
                <div class="diet-card">
                    <div class="diet-card-header">
                        <span class="diet-card-day">@dayPlan.Key</span>
                        <span class="diet-card-kcal">@dayPlan.Value.TotalCaloriesTarget kcal</span>
                    </div>
                    <div class="diet-card-summary">@dayPlan.Value.AiSummary</div>
                    <div style="display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.8rem;">
                        @foreach (var m in dayPlan.Value.Meals.Take(3))
                        {
                            <div style="display: flex; justify-content: space-between;">
                                <span style="color: var(--text);">@m.FoodName</span>
                                <span style="color: var(--text-muted);">@m.Calories kcal</span>
                            </div>
                        }
                        @if (dayPlan.Value.Meals.Count > 3)
                        {
                            <span style="color: var(--primary); font-size: 0.75rem;">+ @(dayPlan.Value.Meals.Count - 3) more items</span>
                        }
                    </div>
                </div>
            </a>
        }
    </div>
}
else
{
    <div class="empty-state fade-up">
        <div class="empty-state-icon"><i class="fa-solid fa-calendar-xmark"></i></div>
        <div class="empty-state-title">No diet history this week</div>
        <div class="empty-state-text">Diet plans appear here after each AI workout generation.</div>
    </div>
}

@section Scripts {
<script>
function submitDietQuickFeedback(rating, difficulty) {
    var buttons = document.querySelectorAll('.diet-feedback-btn');
    buttons.forEach(function(b) {
        b.style.opacity = '0.4';
        b.disabled = true;
        if (parseInt(b.getAttribute('data-rating')) === rating) {
            b.style.opacity = '1';
            b.style.borderColor = 'var(--primary)';
            b.style.background = 'var(--primary-subtle)';
        }
    });

    fetch('@Url.Action("QuickFeedback", "Diet")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: '@Model.UserId', rating: rating, difficulty: difficulty })
    }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.success) {
            document.getElementById('dietFeedbackStatus').style.display = 'block';
        }
    }).catch(function() {
        buttons.forEach(function(b) { b.style.opacity = '1'; b.disabled = false; });
    });
}
</script>
}
