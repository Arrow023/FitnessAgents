@model System.Collections.Generic.Dictionary<string, FitnessAgentsWeb.Models.UserProfile>
@{
    ViewData["Title"] = "User Management";
}

<div class="glass-panel" style="margin-bottom: 2rem; background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(243,244,246,0.9));">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
            <h1 class="section-title">Onboard Family & Friends</h1>
            <p class="section-subtitle">Provision new accounts, set daily notification schedules, and generate unique Webhook URLs.</p>
        </div>
    </div>
</div>

<div class="form-grid">
    <!-- Add New User Form -->
    <div class="glass-panel" style="align-self: start;">
        <h3 style="margin-top: 0; color: var(--text); border-bottom: 2px solid var(--border); padding-bottom: 0.5rem;">Add New User</h3>
        <form method="post" action="/Admin/AddUser" style="margin-top: 1rem;">
            <div class="form-group">
                <label>User ID (No Spaces)</label>
                <input type="text" name="userId" placeholder="e.g. wife_iphone" required />
            </div>
            <div class="form-group">
                <label>First Name</label>
                <input type="text" name="firstName" placeholder="e.g. John" required />
            </div>
            <div class="form-group">
                <label>Last Name</label>
                <input type="text" name="lastName" placeholder="e.g. Doe" required />
            </div>
            <div class="form-group">
                <label>User Password</label>
                <input type="text" name="password" placeholder="e.g. securePass123" required />
            </div>
            <button class="btn" type="submit" style="width: 100%;">Provision New User</button>
        </form>
    </div>

    <!-- Existing Users List -->
    <div class="glass-panel" style="align-self: start;">
        <h3 style="margin-top: 0; color: var(--text); border-bottom: 2px solid var(--border); padding-bottom: 0.5rem;">Provisioned Users</h3>
        
        @if (Model != null && Model.Count > 0)
        {
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                @foreach(var kp in Model)
                {
                    <div style="background: rgba(239, 68, 68, 0.05); padding: 1.2rem; border-radius: 12px; border: 1px dashed var(--border);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <strong style="color: var(--text); font-size: 1.1rem;">@kp.Value.FirstName @kp.Value.LastName (@kp.Key)</strong>
                            
                            <form method="post" action="/Admin/ToggleUser" style="margin: 0;">
                                <input type="hidden" name="userId" value="@kp.Key" />
                                @if (kp.Value.IsActive) {
                                    <button type="submit" style="background: #10b981; color: white; border: none; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; cursor: pointer;">Active</button>
                                } else {
                                    <button type="submit" style="background: #ef4444; color: white; border: none; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; cursor: pointer;">Disabled</button>
                                }
                            </form>
                        </div>
                        <div style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                            📧 @kp.Value.Email <br/>
                            ⏰ Scheduled For: @kp.Value.NotificationTime
                        </div>
                        
                        <div style="margin-top: 0.8rem;">
                            <span style="font-size: 0.75rem; text-transform: uppercase; font-weight: 800; color: var(--primary);">Webhook Endpoint</span>
                            <div style="font-family: monospace; background: white; padding: 0.5rem; border-radius: 6px; font-size: 0.85rem; border: 1px solid var(--border); word-break: break-all; margin-top: 0.2rem;">
                                @ViewBag.BaseUrl/api/webhooks/@kp.Key/generate-workout
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: var(--text-muted); margin-top: 1rem;">No users provisioned yet.</p>
        }
    </div>
</div>
